# NoneBot2 配置
DRIVER=~websockets+~httpx
SUPERUSERS=[]
COMMAND_START=[""]
COMMAND_SEP=[" "]

# QQ 官方机器人凭据，按实际填写
# QQ_IS_SANDBOX=false
# QQ_BOTS=[{"id": "YOUR_APP_ID", "token": "YOUR_BOT_TOKEN", "secret": "YOUR_APP_SECRET", "intent": {"guild_messages": true, "at_messages": true, "c2c_group_at_messages": true}}]

# OneBot V11 正向 WebSocket 连接地址（根据你的 OneBot 实现端修改）
ONEBOT_WS_URLS=["ws://127.0.0.1:6700"]
ONEBOT_ACCESS_TOKEN=

# APScheduler 配置
APSCHEDULER_AUTOSTART=true
